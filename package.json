{
  "name": "axiom",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "db:migrate": "pnpm --filter orchestrator db:migrate",
    "db:studio": "pnpm --filter orchestrator db:studio",
    "test:e2e": "pnpm --filter dashboard test:e2e",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.5",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.3",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "turbo": "^2.8.14",
    "typescript": "^5",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  }
}
